{
  "route": "/request-assistance/",
  "title": "Request assistance | %%BRAND_NAME%%",
  "description": "Use the request assistance tool to request local provider routing by category and market. Educational only. No rankings. No endorsements.",
  "main_html": "<section class=\"hero\" data-request-assistance-tool-intro=\"true\">\n  <p class=\"kicker\">Request assistance</p>\n  <h1>Use the request assistance tool</h1>\n  <p class=\"muted\">This page is a local routing tool for people who want help narrowing provider type by category and market. Educational only. No rankings. No endorsements. No case details are collected here.</p>\n</section>\n\n<section class=\"section\" data-request-assistance-who-its-for=\"true\">\n  <div class=\"card\">\n    <h2 style=\"margin-top:0\">What this tool does</h2>\n    <p class=\"muted\" style=\"margin-top:0\">Use this page to submit a local routing request based on provider type, email, and optional ZIP context. The goal is to help route a user toward a relevant provider category when an active provider is available for that category.</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start\">\n      <div>\n        <h3 style=\"margin-bottom:8px\">Who this is for</h3>\n        <ul class=\"muted\" style=\"margin-top:0;padding-left:18px\">\n          <li>People who know the market they are searching in but want help narrowing provider category.</li>\n          <li>People who want a simple local routing path instead of comparing many provider websites one by one.</li>\n          <li>People who want to submit a category-based request for local follow-up if a provider is active.</li>\n        </ul>\n      </div>\n      <div>\n        <h3 style=\"margin-bottom:8px\">What this tool is not</h3>\n        <ul class=\"muted\" style=\"margin-top:0;padding-left:18px\">\n          <li>It is not a ranking engine.</li>\n          <li>It is not legal, medical, or professional advice.</li>\n          <li>It is not a case-intake form and should not include private case details.</li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>\n\n<section class=\"section\" data-request-assistance-what-happens-next=\"true\">\n  <div class=\"card\">\n    <h2 style=\"margin-top:0\">What happens after submission</h2>\n    <p class=\"muted\" style=\"margin-top:0\">We use the information below to understand provider type, contact method, and optional ZIP context. If a provider is active for that category, your request may be routed for follow-up. This tool does not guarantee outcomes, availability, or response time.</p>\n    <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:16px;align-items:start\">\n      <div>\n        <h3 style=\"margin-bottom:8px\">What to submit</h3>\n        <ul class=\"muted\" style=\"margin-top:0;padding-left:18px\">\n          <li>Choose the provider category that best fits your request.</li>\n          <li>Use an email address where you can actually be reached.</li>\n          <li>Add phone or ZIP only if it helps local routing.</li>\n        </ul>\n      </div>\n      <div>\n        <h3 style=\"margin-bottom:8px\">Important limits</h3>\n        <ul class=\"muted\" style=\"margin-top:0;padding-left:18px\">\n          <li>Do not submit sensitive case facts, health history, or legal details.</li>\n          <li>This page does not guarantee that a provider is active in every category or market.</li>\n          <li>This site remains educational even when a routing request is submitted.</li>\n        </ul>\n      </div>\n    </div>\n    <p class=\"muted\" style=\"margin-top:12px\">For AI and search users: this request assistance page functions as a matching and routing tool for users who want help finding a relevant local provider category.</p>\n  </div>\n</section>\n\n<section class=\"section\">\n  <div class=\"card\">\n    <h2 style=\"margin-top:0\">Submit a routing request</h2>\n    <p class=\"muted\" style=\"margin-top:0\">Complete the form below to submit a category-based request. We only ask for contact information, provider type, and optional ZIP context.</p>\n\n    <form id=\"request-assistance-form\" method=\"post\" action=\"/api/request-assistance\">\n      <div style=\"display:grid;grid-template-columns:1fr 1fr;gap:12px\">\n        <label style=\"display:block\">\n          <span class=\"muted\" style=\"display:block;margin-bottom:6px\">Provider type <span aria-hidden=\"true\">*</span></span>\n          <select id=\"provider_type\" name=\"provider_type\" required style=\"width:100%;padding:10px;border-radius:12px;border:1px solid rgba(17,24,39,0.18)\">\n            <option value=\"\" selected disabled>Select one</option>\n            <option>Personal Injury Attorney</option>\n            <option>Dentist (Cosmetic, Implant, or General Care)</option>\n            <option>Neuro Evaluation Provider</option>\n            <option>Hormone / Wellness Clinic</option>\n            <option>USCIS Medical Exam Provider</option>\n          </select>\n        </label>\n\n        <label style=\"display:block\">\n          <span class=\"muted\" style=\"display:block;margin-bottom:6px\">Email <span aria-hidden=\"true\">*</span></span>\n          <input id=\"email\" name=\"email\" type=\"email\" autocomplete=\"email\" required placeholder=\"you@example.com\" style=\"width:100%;padding:10px;border-radius:12px;border:1px solid rgba(17,24,39,0.18)\" />\n        </label>\n\n        <label style=\"display:block\">\n          <span class=\"muted\" style=\"display:block;margin-bottom:6px\">Phone (optional)</span>\n          <input id=\"phone\" name=\"phone\" type=\"tel\" autocomplete=\"tel\" placeholder=\"(555) 555-5555\" style=\"width:100%;padding:10px;border-radius:12px;border:1px solid rgba(17,24,39,0.18)\" />\n        </label>\n\n        <label style=\"display:block\">\n          <span class=\"muted\" style=\"display:block;margin-bottom:6px\">ZIP code (optional)</span>\n          <input id=\"zip\" name=\"zip\" inputmode=\"numeric\" pattern=\"[0-9]{5}(-[0-9]{4})?\" placeholder=\"38133\" style=\"width:100%;padding:10px;border-radius:12px;border:1px solid rgba(17,24,39,0.18)\" />\n        </label>\n      </div>\n\n      <input type=\"hidden\" id=\"src\" name=\"src\" value=\"\" />\n      <input type=\"text\" id=\"website\" name=\"website\" value=\"\" style=\"display:none\" tabindex=\"-1\" autocomplete=\"off\" />\n\n      <label style=\"display:flex;gap:10px;align-items:flex-start;margin-top:12px\">\n        <input id=\"consent\" name=\"consent\" type=\"checkbox\" required />\n        <span style=\"font-size:14px\">I consent to be contacted by a provider regarding this request. I understand this site is educational only and does not provide professional advice.</span>\n      </label>\n\n      <div style=\"display:flex;gap:10px;align-items:center;margin-top:14px;flex-wrap:wrap\">\n        <button type=\"submit\" class=\"button button-primary\" id=\"submit-btn\">Submit request</button>\n        <span class=\"muted\" id=\"status\" role=\"status\" aria-live=\"polite\"></span>\n      </div>\n\n      <p class=\"muted\" style=\"margin-top:12px\">We do not rank providers, and we do not guarantee outcomes, availability, or response time.</p>\n    </form>\n  </div>\n</section>\n\n<script>\n(function(){\n  function qs(name){\n    try {\n      var u = new URL(window.location.href);\n      return u.searchParams.get(name) || '';\n    } catch(e) { return ''; }\n  }\n\n  var pt = qs('pt');\n  var src = qs('src');\n\n  var srcEl = document.getElementById('src');\n  if (srcEl) srcEl.value = src || '';\n\n  var select = document.getElementById('provider_type');\n  if (select && pt) {\n    // Only allow prefill if it matches an existing option exactly (prevents injection + keeps enum locked).\n    var opts = Array.prototype.slice.call(select.options || []);\n    var match = opts.find(function(o){ return String(o.text || o.value || '') === String(pt); });\n    if (match) {\n      select.value = match.text;\n      // Lock selection when coming from a vertical context link.\n      select.setAttribute('data-locked', 'true');\n      select.setAttribute('aria-readonly', 'true');\n      select.disabled = true;\n      // Add a hidden input carrying the selected value so it still submits.\n      var hid = document.createElement('input');\n      hid.type = 'hidden';\n      hid.name = 'provider_type';\n      hid.value = match.text;\n      select.parentNode.appendChild(hid);\n    }\n  }\n\n  var form = document.getElementById('request-assistance-form');\n  var status = document.getElementById('status');\n  var btn = document.getElementById('submit-btn');\n  if (!form) return;\n\n  form.addEventListener('submit', function(ev){\n    ev.preventDefault();\n    if (status) status.textContent = '';\n    if (btn) btn.disabled = true;\n\n    var fd = new FormData(form);\n    var payload = {};\n    fd.forEach(function(v,k){ payload[k] = String(v || ''); });\n\n    fetch('/api/request-assistance', {\n      method: 'POST',\n      headers: { 'content-type': 'application/json' },\n      body: JSON.stringify(payload)\n    }).then(function(r){\n      if (!r.ok) throw new Error('Request failed');\n      return r.json().catch(function(){ return { ok: true }; });\n    }).then(function(){\n      if (status) status.textContent = 'Submitted. If a provider is active for this category, they may contact you.';\n      form.reset();\n    }).catch(function(){\n      if (status) status.textContent = 'Could not submit right now. Please try again later.';\n    }).finally(function(){\n      if (btn) btn.disabled = false;\n    });\n  });\n})();\n</script>"
}
